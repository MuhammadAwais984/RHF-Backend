{
  "kind": "collectionType",
  "collectionName": "recipe_categories",
  "info": {
    "singularName": "recipe-category",
    "pluralName": "recipe-categories",
    "displayName": "RecipeCategory"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "Name"
    },
    "categoryImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "altText": {
      "type": "string"
    },
    "recipes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::recipe.recipe",
      "mappedBy": "recipe_category"
    }
  }
}
