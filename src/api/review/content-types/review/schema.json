{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Review"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "comment": {
      "type": "string"
    },
    "statu": {
      "type": "enumeration",
      "required": false,
      "default": "PENDING",
      "enum": [
        "PENDING",
        "APPROVED",
        "REJECTED"
      ]
    },
    "recipe": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::recipe.recipe",
      "inversedBy": "reviews"
    }
  }
}
